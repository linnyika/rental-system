<?xml version="1.0" encoding="utf-8"?>
<network-security-config>
    <!-- Allow HTTP for development against the Laravel API.
         Replace the API URL with HTTPS before production deployment. -->
    <base-config cleartextTrafficPermitted="true">
        <trust-anchors>
            <certificates src="system" />
        </trust-anchors>
    </base-config>
</network-security-config>
